---
const PILLAR_ACCENT: Record<string, string> = {
  News: "#E8590C",
  Sarkari: "#1E2A4A",
  Ghumo: "#0F766E",
  Tools: "#C9962E",
  Gyaan: "#1E2A4A",
  Paisa: "#0F766E",
};

interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  image?: string;
  publishedAt: string;
}
const { title, slug, excerpt, category, image, publishedAt } = Astro.props;
const accent = PILLAR_ACCENT[category] ?? "#E8590C";
const dateLabel = new Date(publishedAt).toLocaleDateString("en-IN", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---
<a class="article-card" href={`/news/${slug}`}>
  {image && <img src={image} alt={title} loading="lazy" />}
  <div class="article-card-body">
    <span class="chip" style={`background:${accent}`}>{category}</span>
    <h3>{title}</h3>
    <p>{excerpt}</p>
    <span class="date">{dateLabel}</span>
  </div>
</a>

<style>
  .article-card {
    display: block;
    background: var(--ba-card);
    border: 1px solid var(--ba-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--t-fast) var(--ease), transform var(--t-fast) var(--ease);
  }
  .article-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-2px); }
  .article-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .article-card-body { padding: var(--sp-3); }
  .chip {
    display: inline-block; color: #fff; font-size: 0.7rem; font-weight: 700;
    padding: 2px 10px; border-radius: var(--radius-pill); margin-bottom: var(--sp-1);
  }
  .article-card h3 {
    font-family: var(--font-display); color: var(--ba-heading);
    font-size: 1.1rem; margin: 4px 0 6px; line-height: 1.3;
  }
  .article-card p { font-size: 0.875rem; color: var(--ba-ink-soft); margin: 0 0 8px; }
  .article-card .date { font-size: 0.75rem; color: var(--ba-ink-soft); }
</style>

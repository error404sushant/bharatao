---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="About | BharatAo" description="What BharatAo is and how it's built.">
  <div class="wrap section" style="max-width:760px;">
    <h1 class="article-title" style="font-family:var(--font-display);color:var(--ba-heading);">About BharatAo</h1>
    <p>BharatAo is an India-first news and utility platform — news, government
       updates, travel guides, free tools, and personal finance explainers in
       one place, the way you'd check WhatsApp every morning.</p>
    <p>Articles are drafted with AI assistance from cited sources, and every
       News and Sarkari (government) story is reviewed by a human before it
       goes live. Nothing is auto-published on sensitive topics.</p>
  </div>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Corrections Policy | BharatAo" description="How BharatAo handles factual errors.">
  <div class="wrap section" style="max-width:760px;">
    <h1 class="article-title" style="font-family:var(--font-display);color:var(--ba-heading);">Corrections Policy</h1>
    <p>Articles on BharatAo are AI-drafted from cited sources and reviewed by
       a human editor before publication. If you spot a factual error, please
       tell us at <a href="mailto:support@facenova.uk">support@facenova.uk</a> —
       we'll investigate and, if confirmed, correct the article and add a
       visible correction note at the top explaining what changed and why.</p>
    <p>We'd rather be corrected than be wrong. Trust is the whole point.</p>
  </div>
</BaseLayout>

# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit real secrets.

AGENT_API_BASE_URL=https://agent.facenova.uk/v1
AGENT_API_KEY=put-your-NEW-regenerated-key-here
# This gateway routes to many providers under aliases like auto/best-chat,
# auto/best-coding, auto/cheap -- see GET /v1/models for the full list.
# It is NOT plain OpenAI, so a plain "gpt-4o-mini" model id will 404.
AGENT_MODEL=auto/best-chat

# Phase 0 site is Astro (site/), not WordPress -- A9 Publisher writes approved
# drafts directly into site/src/content/articles/. No site credentials needed here.

IMAGE_API_KEY=
NEWS_API_KEY=

# How many topics A2 News Writer should draft per run (keep small for local testing)
NEWS_WRITER_COUNT=1
